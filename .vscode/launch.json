{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Server",
            "request": "launch",
            "runtimeArgs": [
                "run",
                "dev"
            ],
            "runtimeExecutable": "npm",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "type": "node",
            "cwd": "${workspaceFolder}/ez_finance_server"
        },
        {
            "name": "ez_finance_app",
            "cwd": "ez_finance_app",
            "request": "launch",
            "type": "dart"
        },
        {
            "name": "ez_finance_app (profile mode)",
            "cwd": "ez_finance_app",
            "request": "launch",
            "type": "dart",
            "flutterMode": "profile"
        },
        {
            "name": "ez_finance_app (release mode)",
            "cwd": "ez_finance_app",
            "request": "launch",
            "type": "dart",
            "flutterMode": "release"
        },
        
    ]
}